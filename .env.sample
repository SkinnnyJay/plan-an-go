# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
NODE_ENV=development
PRD_FILE=PRD.md
STREAM_OUTPUT=false
USE_SLACK=true
SLACK_USE_THREADS=true

# -----------------------------------------------------------------------------
# CLI API keys (optional; if set, auth-cli.sh skips web login for that provider)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# plan-an-go CLI and models
# -----------------------------------------------------------------------------
PLAN_AN_GO_CLI=claude
PLAN_AN_GO_CLI_FLAGS=
PLAN_AN_GO_CLAUDE_MODEL=claude-sonnet-4-20250514
PLAN_AN_GO_CODEX_MODEL=codex-20250301

# -----------------------------------------------------------------------------
# Slack (optional; app-specific)
# -----------------------------------------------------------------------------
PLAN_AN_GO_SLACK_APP_ID="<SLACK_APP_ID>"
PLAN_AN_GO_SLACK_APP_CLIENT_ID="<SLACK_APP_CLIENT_ID>"
PLAN_AN_GO_SLACK_APP_CLIENT_SECRET="<SLACK_APP_CLIENT_SECRET>"
PLAN_AN_GO_SLACK_APP_SIGNING_SECRET="<SLACK_APP_SIGNING_SECRET>"
PLAN_AN_GO_SLACK_APP_VERIFICATION_TOKEN="<SLACK_APP_VERIFICATION_TOKEN>"
PLAN_AN_GO_SLACK_APP_ACCESS_TOKEN="<SLACK_APP_ACCESS_TOKEN>"
PLAN_AN_GO_SLACK_APP_REFRESH_TOKEN="<SLACK_APP_REFRESH_TOKEN>"
PLAN_AN_GO_SLACK_APP_BOT_OAUTH_TOKEN="<SLACK_APP_BOT_OAUTH_TOKEN>"
PLAN_AN_GO_SLACK_CLIENT_ID="<SLACK_APP_CLIENT_ID>"
PLAN_AN_GO_SLACK_CLIENT_SECRET="<SLACK_APP_CLIENT_SECRET>"
