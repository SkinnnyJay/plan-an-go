# -----------------------------------------------------------------------------
# plan-an-go environment — copy to .env and set values. Full reference: docs/ENV-README.md
# -----------------------------------------------------------------------------
#
# Output directory (CLI, not env): To build into a specific dir instead of ./
#   Use --out-dir DIR with run, forever, planner, or prd (e.g. --out-dir ./example/todo).
#   Dir is created if missing; use unique dirs per project. See docs/ENV-README.md and README.
# Optional cleanup after pipeline exit: plan-an-go-forever --clean-after --force (requires both).
#
# -----------------------------------------------------------------------------

# Optional (generic; not required by plan-an-go scripts)
# LOG_LEVEL=debug
# NODE_ENV=development
# PLAN_AN_GO_PRD_FILE=PRD.md

# Plan & pipeline
PLAN_FILE=PLAN.md
# PLAN_AN_GO_AGENTS_DEBUG=1   # Optional: log missing agent config fields and defaults (stderr).
# PLAN_AN_GO_ROOT=              # Optional: operating root (scripts/plan-an-go). Unset = repo root or --root.
# progress.log, history.log, pipeline-tail.log, and agent artifact files (e.g. task-*-output.log) go under this dir
PLAN_AN_GO_TMP=./tmp
PLAN_AN_GO_STREAM_OUTPUT=false
# PLAN_AN_GO_VERBOSE=false   # true = full iteration summaries and plan-check output (or use --verbose).
# PLAN_AN_GO_QUIET=false    # true = only header, errors, and final message (or use --quiet).
# Slack is off by default (pipeline does not launch Slack). Set true or use --slack-enable to enable; if tokens are unset or a post fails, we warn and continue.
PLAN_AN_GO_USE_SLACK=false
PLAN_AN_GO_SLACK_USE_THREADS=true

# CLI API keys. This project uses only OpenAI for text and image (Codex CLI).
# Set OPENAI_API_KEY or PLAN_AN_GO_OPENAI_API_KEY; leave Anthropic unset if not using Claude.
# PLAN_AN_GO_ANTHROPIC_API_KEY=
PLAN_AN_GO_OPENAI_API_KEY=

# CLI and models (codex = OpenAI; claude = Anthropic)
PLAN_AN_GO_CLI=codex
# Shared flags (used for whichever CLI is selected); overridden by CLI-specific vars when unset
PLAN_AN_GO_CLI_FLAGS=
# Per-CLI flags (used when PLAN_AN_GO_CLI_FLAGS is unset)
# PLAN_AN_GO_CLAUDE_FLAGS=--max-tokens 4096
# PLAN_AN_GO_CODEX_FLAGS=--full-auto
PLAN_AN_GO_CLAUDE_MODEL=claude-sonnet-4-20250514
# Codex: leave unset so the CLI picks an account-appropriate model (codex-20250301 is not supported with ChatGPT accounts)
# PLAN_AN_GO_CODEX_MODEL=codex-20250301

# Voice summary (spoken announcement after each completed task). Requires PLAN_AN_GO_OPENAI_API_KEY and jq.
PLAN_AN_GO_TTS_AFTER_TASK=false
PLAN_AN_GO_TTS_SUMMARY_PROMPT_FILE=assets/prompts/voice-summary.md
PLAN_AN_GO_TTS_SUMMARY_MODEL=gpt-4o-mini
PLAN_AN_GO_TTS_TONE=professional
PLAN_AN_GO_TTS_MODEL=tts-1
PLAN_AN_GO_TTS_VOICE=alloy
PLAN_AN_GO_TTS_SPEED=1.0

# Slack (optional; set PLAN_AN_GO_USE_SLACK=true to enable). Bot token preferred for posting.
PLAN_AN_GO_SLACK_APP_BOT_OAUTH_TOKEN=
PLAN_AN_GO_SLACK_APP_ACCESS_TOKEN=
PLAN_AN_GO_SLACK_APP_REFRESH_TOKEN=
PLAN_AN_GO_SLACK_APP_CLIENT_ID=
PLAN_AN_GO_SLACK_APP_CLIENT_SECRET=
PLAN_AN_GO_SLACK_APP_ID=
PLAN_AN_GO_SLACK_APP_SIGNING_SECRET=
PLAN_AN_GO_SLACK_APP_VERIFICATION_TOKEN=